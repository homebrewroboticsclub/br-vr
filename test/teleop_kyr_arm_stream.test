<launch>
  <!-- Minimal graph: KYR proxy + teleop_fetch (no MoveIt / fast_ik). -->
  <node pkg="KYR" type="kyr_proxy_node.py" name="kyr_proxy" output="screen">
    <!-- Empty list => SessionModule.verify_grant bypass (see kyr/session_module.py). -->
    <rosparam param="trusted_raid_keys">[]</rosparam>
  </node>

  <node pkg="teleop_fetch" type="teleop_node.py" name="teleop_fetch" output="screen">
    <rosparam command="load" file="$(find teleop_fetch)/config/teleop.yaml" />
  </node>

  <test
    test-name="test_teleop_kyr_arm_stream"
    pkg="teleop_fetch"
    type="test_teleop_kyr_arm_stream.py"
    time-limit="120.0"
  />
</launch>
